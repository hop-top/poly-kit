name: CI (Kotlin / Android)

on:
  push:
    branches: [main]
    paths:
      - "mobile/android/**"
      - "**.kt"
      - "**.kts"
      - "**/build.gradle*"
      - "**/gradle.properties"
      - "**/settings.gradle*"
  pull_request:
    branches: [main]
    paths:
      - "mobile/android/**"
      - "**.kt"
      - "**.kts"
      - "**/build.gradle*"
      - "**/gradle.properties"
      - "**/settings.gradle*"

permissions:
  contents: read

# Android / Kotlin builds run on Ubuntu — much cheaper than macOS.
# Java 17 (Temurin) matches AGP 8.x defaults; Android command-line tools
# install via setup-android.

jobs:
  lint:
    name: ktlint + Android lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: gradle-${{ runner.os }}-${{ hashFiles('**/*.gradle*', '**/gradle.properties') }}
          restore-keys: gradle-${{ runner.os }}-

      - name: ktlint
        # ktlintCheck is provided by the ktlint Gradle plugin; repos that
        # don't yet adopt it will skip silently. Detekt is an alternative
        # if the project prefers richer static analysis.
        run: |
          if [ -f mobile/android/gradlew ]; then
            cd mobile/android && ./gradlew ktlintCheck --no-daemon || true
          elif [ -f gradlew ]; then
            ./gradlew ktlintCheck --no-daemon || true
          fi

      - name: Android lint
        run: |
          if [ -f mobile/android/gradlew ]; then
            cd mobile/android && ./gradlew lint --no-daemon
          elif [ -f gradlew ]; then
            ./gradlew lint --no-daemon
          fi

      - name: Upload lint reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: android-lint
          path: |
            **/build/reports/lint-results-*.html
            **/build/reports/lint-results-*.xml

  test:
    name: Unit tests
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: gradle-${{ runner.os }}-${{ hashFiles('**/*.gradle*', '**/gradle.properties') }}
          restore-keys: gradle-${{ runner.os }}-

      - name: Setup Android SDK
        uses: android-actions/setup-android@v3

      - name: Run unit tests
        run: |
          if [ -f mobile/android/gradlew ]; then
            cd mobile/android && ./gradlew test --no-daemon
          elif [ -f gradlew ]; then
            ./gradlew test --no-daemon
          fi

      - name: Upload test reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: android-tests
          path: |
            **/build/test-results/**/*.xml
            **/build/reports/tests/

  build:
    name: assembleDebug
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: gradle-${{ runner.os }}-${{ hashFiles('**/*.gradle*', '**/gradle.properties') }}
          restore-keys: gradle-${{ runner.os }}-

      - name: Setup Android SDK
        uses: android-actions/setup-android@v3

      - name: assembleDebug
        # Debug APK only — release signing happens in a separate workflow
        # with secrets scoped there.
        run: |
          if [ -f mobile/android/gradlew ]; then
            cd mobile/android && ./gradlew assembleDebug --no-daemon
          elif [ -f gradlew ]; then
            ./gradlew assembleDebug --no-daemon
          fi

      - name: Upload debug APK
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: app-debug-apk
          path: "**/build/outputs/apk/debug/*.apk"
