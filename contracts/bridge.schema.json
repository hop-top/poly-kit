{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hop.top/kit/contracts/bridge.schema.json",
  "title": "Payload",
  "description": "kit/bridge wire payload — authoritative JSON wire format. contracts/bridge.proto documents semantics + binary wire only; JSON keys are defined here. Exactly one of text/url/file/blob must be set.",
  "type": "object",
  "required": ["id"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "ULID generated by the shell."
    },
    "source": {
      "type": "string",
      "description": "Origin shell, e.g. macos.share-ext."
    },
    "source_version": {
      "type": "string"
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix milliseconds at shell capture time."
    },
    "text": { "$ref": "#/definitions/Text" },
    "url":  { "$ref": "#/definitions/Url" },
    "file": { "$ref": "#/definitions/File" },
    "blob": { "$ref": "#/definitions/Blob" },
    "meta": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "oneOf": [
    {
      "required": ["text"],
      "not": {
        "anyOf": [
          { "required": ["url"] },
          { "required": ["file"] },
          { "required": ["blob"] }
        ]
      }
    },
    {
      "required": ["url"],
      "not": {
        "anyOf": [
          { "required": ["text"] },
          { "required": ["file"] },
          { "required": ["blob"] }
        ]
      }
    },
    {
      "required": ["file"],
      "not": {
        "anyOf": [
          { "required": ["text"] },
          { "required": ["url"] },
          { "required": ["blob"] }
        ]
      }
    },
    {
      "required": ["blob"],
      "not": {
        "anyOf": [
          { "required": ["text"] },
          { "required": ["url"] },
          { "required": ["file"] }
        ]
      }
    }
  ],
  "definitions": {
    "Text": {
      "type": "object",
      "required": ["body"],
      "additionalProperties": false,
      "properties": {
        "body": { "type": "string" },
        "mime": { "type": "string" }
      }
    },
    "Url": {
      "type": "object",
      "required": ["href"],
      "additionalProperties": false,
      "properties": {
        "href": { "type": "string" },
        "title": { "type": "string" },
        "selection": { "type": "string" }
      }
    },
    "File": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "mime": { "type": "string" },
        "size": { "type": "integer" }
      }
    },
    "Blob": {
      "type": "object",
      "required": ["data"],
      "additionalProperties": false,
      "properties": {
        "data": {
          "type": "string",
          "description": "Base64-encoded bytes per proto3 JSON mapping.",
          "contentEncoding": "base64",
          "pattern": "^[A-Za-z0-9+/]*={0,2}$"
        },
        "mime": { "type": "string" },
        "filename": { "type": "string" }
      }
    }
  }
}
