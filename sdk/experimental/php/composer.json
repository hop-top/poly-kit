{
  "name": "hop-top/kit",
  "description": "Cross-language CLI UX parity toolkit",
  "type": "library",
  "license": "MIT",
  "version": "0.4.0",
  "require": {
    "php": "^8.3",
    "guzzlehttp/guzzle": "^7.9",
    "hop-top/uri": "^0.2.0@alpha"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "HopTop\\Kit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HopTop\\Kit\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
