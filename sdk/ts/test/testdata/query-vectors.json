    "expected": {"Provider": "anthropic"},
    "description": "whitespace — leading/trailing trimmed"
  },
  {
    "input": "provider:anthropic  reasoning:true",
    "expected": {"Provider": "anthropic", "Reasoning": true},
    "description": "whitespace — multiple spaces between tokens"
  },
  {
    "input": "provider:",
