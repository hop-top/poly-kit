    "description": "kitchen sink — all fields set"
  },
  {
    "input": "in:text out:code reasoning:true openweights:false provider:meta family:llama coder",
    "expected": {
      "Input": "text",
      "Output": "code",
      "Reasoning": true,
      "OpenWeights": false,
      "Provider": "meta",
      "Family": "llama",
      "Query": "coder"
    },
    "description": "kitchen sink — all fields + free-text"
  }
