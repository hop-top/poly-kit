[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{.Name}}"
version = "0.0.0"
description = "{{.Description}}"
readme = "README.md"
license = "{{.License}}"
requires-python = ">=3.12"
authors = [
    { name = "{{.Author}}", email = "{{.Email}}" },
]
dependencies = [
    "typer>=0.12.0",
    "rich>=13.0.0",
]

[project.scripts]
"{{.Name}}" = "{{.Name}}.cli:app"

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=5.0.0",
    "mypy>=1.10.0",
    "ruff>=0.5.0",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{.Name}}"]

[tool.mypy]
python_version = "3.12"
strict = true
warn_return_any = true
warn_unused_configs = true

[tool.pytest.ini_options]
testpaths = ["tests"]
